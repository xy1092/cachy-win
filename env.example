# Copy this file to env.local and edit it for your machine.
# Keep env.local out of git; it contains host-specific device paths.

# VM names. The two profiles must not run at the same time if they share a disk.
CACHY_WIN_GAMING_NAME=cachy-win-gaming
CACHY_WIN_OFFICE_NAME=cachy-win-office
LIBVIRT_URI=qemu:///system

# Stable UUIDs for libvirt. Generate your own with: uuidgen
GAMING_VM_UUID=11111111-1111-4111-8111-111111111111
OFFICE_VM_UUID=22222222-2222-4222-8222-222222222222

# Default backend: qcow2 is recommended. physical is advanced and riskier.
# Valid values: qcow2, physical
DISK_BACKEND=qcow2
WINDOWS_DISK_IMAGE=/var/lib/libvirt/images/cachy-win.qcow2

# Advanced physical boot. Prefer /dev/disk/by-id/... or /dev/disk/by-partuuid/...
# Do not use a whole disk if any partition on that disk is mounted by Linux.
PHYSICAL_WINDOWS_DISK=
PHYSICAL_WINDOWS_EFI=

# Windows install ISO and VirtIO driver ISO are intentionally not launched here.
# Install the VM once with virt-manager or virt-install, then use these profiles.

# Office profile: light resources, SPICE display, VirtIO devices.
OFFICE_MEMORY_MIB=8192
OFFICE_VCPUS=4
OFFICE_CPUSET=0-3
OFFICE_CPU_SOCKETS=1
OFFICE_CPU_CORES=2
OFFICE_CPU_THREADS=2

# Gaming profile: more resources, host-passthrough CPU, optional hugepages, VFIO GPU.
GAMING_MEMORY_MIB=24576
GAMING_VCPUS=12
GAMING_CPUSET=0-11
GAMING_CPU_SOCKETS=1
GAMING_CPU_CORES=6
GAMING_CPU_THREADS=2
GAMING_USE_HUGEPAGES=1

# Dedicated GPU PCI addresses for passthrough.
# Find them with: lspci -nn | grep -Ei 'vga|3d|audio'
GAMING_GPU_VIDEO_PCI=0000:01:00.0
GAMING_GPU_AUDIO_PCI=0000:01:00.1

# Whether gpu-bind.sh is allowed to stop/start the display manager.
# Set to 1 only when the passthrough GPU is currently used by the host session.
STOP_DISPLAY_MANAGER=0
DISPLAY_MANAGER=display-manager

# Libvirt OVMF paths differ by distribution. These are common Arch/CachyOS paths.
OVMF_CODE=/usr/share/edk2/x64/OVMF_CODE.secboot.4m.fd
OVMF_VARS_GAMING=/var/lib/libvirt/qemu/nvram/cachy-win-gaming_VARS.fd
OVMF_VARS_OFFICE=/var/lib/libvirt/qemu/nvram/cachy-win-office_VARS.fd

# Optional: SMBIOS values can reduce Windows activation churn between profiles.
# Leave empty unless you know the values you want to pin.
SMBIOS_MANUFACTURER=
SMBIOS_PRODUCT=
SMBIOS_SERIAL=
