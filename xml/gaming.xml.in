<domain type='kvm'>
  <name>${VM_NAME}</name>
  <uuid>${VM_UUID}</uuid>
  <metadata>
    <cachy-win:profile xmlns:cachy-win='https://github.com/xy1092/cachy-win'>gaming</cachy-win:profile>
  </metadata>
  <memory unit='MiB'>${MEMORY_MIB}</memory>
  <currentMemory unit='MiB'>${MEMORY_MIB}</currentMemory>
  <vcpu placement='static' cpuset='${CPUSET}'>${VCPUS}</vcpu>
${MEMORY_BACKING_XML}
${SMBIOS_XML}
  <os firmware='efi'>
    <type arch='x86_64' machine='pc-q35-8.2'>hvm</type>
    <loader readonly='yes' type='pflash'>${OVMF_CODE}</loader>
    <nvram>${OVMF_VARS}</nvram>
${SMBIOS_MODE_XML}
  </os>
  <features>
    <acpi/>
    <apic/>
    <hyperv mode='custom'>
      <relaxed state='on'/>
      <vapic state='on'/>
      <spinlocks state='on' retries='8191'/>
      <vpindex state='on'/>
      <runtime state='on'/>
      <synic state='on'/>
      <stimer state='on'/>
      <frequencies state='on'/>
    </hyperv>
    <vmport state='off'/>
    <ioapic driver='kvm'/>
  </features>
  <cpu mode='host-passthrough' check='none' migratable='off'>
    <topology sockets='${CPU_SOCKETS}' cores='${CPU_CORES}' threads='${CPU_THREADS}'/>
  </cpu>
  <clock offset='localtime'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='no'/>
    <timer name='hypervclock' present='yes'/>
    <timer name='tsc' present='yes' mode='native'/>
  </clock>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>
  <pm>
    <suspend-to-mem enabled='no'/>
    <suspend-to-disk enabled='no'/>
  </pm>
  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>
${SYSTEM_DISK_XML}
    <controller type='usb' model='qemu-xhci'/>
    <controller type='pci' model='pcie-root'/>
    <controller type='scsi' model='virtio-scsi'/>
    <interface type='network'>
      <source network='default'/>
      <model type='virtio'/>
    </interface>
    <input type='keyboard' bus='usb'/>
    <input type='mouse' bus='usb'/>
    <hostdev mode='subsystem' type='pci' managed='yes'>
      <driver name='vfio'/>
      <source>
        <address domain='${GPU_VIDEO_DOMAIN}' bus='${GPU_VIDEO_BUS}' slot='${GPU_VIDEO_SLOT}' function='${GPU_VIDEO_FUNCTION}'/>
      </source>
    </hostdev>
${GPU_AUDIO_XML}
    <memballoon model='none'/>
    <rng model='virtio'>
      <backend model='random'>/dev/urandom</backend>
    </rng>
  </devices>
</domain>
